# ============================================================
# Tessera — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Only set the providers you want to use (at least one AI provider required).
# Model selection is done via the Dashboard UI dropdown, not here.
# ============================================================

# --- Hackathon (required for submission features) ---
SYNTHESIS_API_KEY=
SYNTHESIS_PARTICIPANT_ID=
SYNTHESIS_TEAM_ID=
SYNTHESIS_PROJECT_UUID=

# --- Data Sources ---
OSO_API_KEY=

# --- Social ---
MOLTBOOK_API_KEY=

# ============================================================
# AI Providers — set one or more API keys to enable models
# ============================================================
# Each provider unlocks multiple models selectable from the Dashboard:
#
#   Claude CLI    → claude-opus-4-6, claude-sonnet-4-6
#                   Auto-detected if `claude` binary is installed. No key needed.
#                   Install: npm i -g @anthropic-ai/claude-code && claude login
#
#   Claude API    → claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_API_KEY=
#
#   Google Gemini → gemini-2.5-pro, gemini-2.5-flash, gemini-3.1-pro-preview,
#                   gemini-3-flash-preview, gemini-2.5-flash-lite
#                   Free tier: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-3-flash-preview
#                   Paid tier: gemini-2.5-pro, gemini-3.1-pro-preview
#                   Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
#   OpenAI       → gpt-4o, gpt-4o-mini, o3-mini
OPENAI_API_KEY=

# ============================================================
# Advanced (optional — usually not needed)
# ============================================================
# Disable Claude CLI auto-detection:
# CLAUDE_CLI_DISABLED=true
#
# Server port (default: 3001):
# PORT=3001
