# Tessera — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Hackathon (required) ──
SYNTHESIS_API_KEY=sk-synth-...
SYNTHESIS_PARTICIPANT_ID=...
SYNTHESIS_TEAM_ID=...
SYNTHESIS_PROJECT_UUID=...

# ── AI Providers (at least one required for qualitative features) ──
# Providers are tried in fallback order:
#   1. Claude API (ANTHROPIC_API_KEY)
#   2. Claude CLI (auto-detected if `claude` binary exists, uses Max plan)
#   3. Gemini (GEMINI_API_KEY)
#   4. OpenAI (OPENAI_API_KEY)
#   5. Antigravity (ANTIGRAVITY_URL)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTIGRAVITY_URL=

# ── Claude CLI (auto-detected, no key needed) ──
# If `claude` CLI is installed (Claude Code / Max plan), it is auto-added to the chain.
# Set CLAUDE_CLI_DISABLED=true to skip it.
# CLAUDE_CLI_DISABLED=true
# CLAUDE_CLI_MODEL=sonnet

# ── Model Overrides (optional) ──
# CLAUDE_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4o
# ANTIGRAVITY_MODEL=claude-sonnet-4-5-thinking

# ── Data Sources (optional) ──
# OSO_API_KEY=
