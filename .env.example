# Tessera — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── AI Providers ──
# Tessera tries providers in this order. You only need ONE.
#
# RECOMMENDED: Claude CLI (no key needed)
#   If you have Claude Code installed (Max plan / 5x subscription),
#   Tessera auto-detects it. No configuration needed.
#   Install: npm i -g @anthropic-ai/claude-code && claude login
#
# ALTERNATIVE: Set one of these API keys
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENAI_API_KEY=sk-...
# ANTIGRAVITY_URL=http://localhost:8080

# ── Claude CLI Options (optional) ──
# CLAUDE_CLI_DISABLED=true          # Set to skip Claude CLI
# CLAUDE_CLI_MODEL=sonnet           # Options: opus, sonnet, haiku

# ── Model Overrides (optional) ──
# CLAUDE_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4o

# ── Data Sources (optional) ──
# OSO_API_KEY=...                   # Higher rate limits for Open Source Observer
