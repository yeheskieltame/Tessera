# Tessera — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── AI Providers (at least one required for qualitative features) ──
# Providers are tried in fallback order: Claude → Gemini → OpenAI → Antigravity
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTIGRAVITY_URL=

# ── Model Overrides (optional) ──
# CLAUDE_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4o
# ANTIGRAVITY_MODEL=claude-sonnet-4-5-thinking

# ── Data Sources (optional) ──
# OSO_API_KEY=
